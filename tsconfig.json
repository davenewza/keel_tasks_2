{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "noImplicitAny": false,
    "paths": {
      "@teamkeel/sdk": [
        "./.build/sdk"
      ],
      "@teamkeel/testing": [
        "./.build/testing"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "target": "ES2022",
    "types": [
      "node"
    ]
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "**/*.ts",
    ".build/**/*.ts"
  ]
}